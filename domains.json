      "id": 1,
      "name": "Understanding Business Analysis",
      "weight_pct": 20,
      "source_material": "Business Analysis Standard",
      "tier": "foundational",
      "activity_statements": [
        {
          "id": "1.1",
          "text": "Define business analysis, describe its role in enabling change, and outline key activities across contexts.",
          "babok_source_refs": [
            {
              "source": "Business Analysis Standard",
              "page": 5,
              "section": "2.1 Defining Business Analysis"
            }
          ]
        },
        {
          "id": "1.2",
          "text": "Describe the six BACCM concepts, explain how they relate, and use them to support structured thinking.",
          "babok_source_refs": [
            {
              "source": "Business Analysis Standard",
              "page": 5,
              "section": "2.2 A Model for Effective Analysis \u2014 BACCM\u2122 / 2.3 Using the BACCM\u2122"
            }
          ]
        },
        {
          "id": "1.3",
          "text": "Explain how business analysis supports value creation and benefits organizations in various industries.",
          "babok_source_refs": [
            {
              "source": "Business Analysis Standard",
              "page": 7,
              "section": "2.4 The Importance of Business Analysis"
            }
          ]
        },
        {
          "id": "1.4",
          "text": "Define value in business analysis and explain how outcomes are assessed to support value realization.",
          "babok_source_refs": [
            {
              "source": "Business Analysis Standard",
              "page": 7,
              "section": "2.5 Outcomes and Value Creation"
            }
          ]
        }
      ]
    },
